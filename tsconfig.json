{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "lib": ["ES2022", "dom"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "public",
    "coverage",
    "test-report"
  ]
}
